## 6. Prompt Interceptor 패턴

### manifest.json
```json
{
    "display_name": "My Interceptor",
    "generate_interceptor": "myInterceptorFn",
    "js": "index.js",
    "author": "Author"
}
```

### index.js
```javascript
globalThis.myInterceptorFn = async function(chat, contextSize, abort, type) {
    // 조용한 생성은 무시
    if (type === 'quiet') return;

    const settings = getSettings();
    if (!settings.enabled) return;

    // 시스템 노트 삽입 예시
    const note = {
        is_user: false,
        name: 'System',
        send_date: Date.now(),
        mes: 'Additional context from my extension.',
    };
    // 마지막 메시지 앞에 삽입
    chat.splice(chat.length - 1, 0, note);

    // 생성 중단 예시:
    // abort();         // 이 인터셉터만 중단
    // abort(true);     // 이후 인터셉터도 모두 중단
};
```

